# Server Configuration
PORT=5000
NODE_ENV=development
ADMIN_REGISTRATION_SECRET=your_admin_registration_secret_code

# Firebase Configuration
# Path to your Firebase serviceAccountKey.json.
# If left commented out, the app will look for serviceAccountKey.json in SecureCRM/backend/config/
# FIREBASE_SERVICE_ACCOUNT_KEY=./config/serviceAccountKey.json

# JWT Configuration
JWT_SECRET=replace_this_with_a_long_random_cryptographic_key_in_production
JWT_EXPIRES_IN=1h
